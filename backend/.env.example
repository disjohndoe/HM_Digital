# Application
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/medical_mvp

# Security
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
